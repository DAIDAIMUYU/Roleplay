# Frontend public env
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_MODE=development

# Server / Edge Function secrets only, never expose to browser
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
OWNER_PROVIDER_MODE=disabled

# Optional deployment
APP_ENV=development
APP_PUBLIC_URL=http://localhost:5173

# Stage 7B only: server-side encryption secret for hosted user API credentials.
# Never expose to browser. Do not implement hosted key storage before Stage 7B.
USER_API_CREDENTIALS_ENCRYPTION_KEY=
