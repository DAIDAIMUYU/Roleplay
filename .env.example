# Frontend public env
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
VITE_APP_MODE=development

# Server / Edge Function secrets only, never expose to browser
DEEPSEEK_API_KEY=
OPENAI_API_KEY=
OWNER_PROVIDER_MODE=disabled

# Optional deployment
APP_ENV=development
APP_PUBLIC_URL=http://localhost:5173

# Stage 8.1: server-side encryption secret for hosted encrypted API credentials.
# Supabase Edge Functions only. Never expose to browser or any VITE_* variable.
API_KEY_ENCRYPTION_SECRET=replace-with-strong-random-base64-secret
